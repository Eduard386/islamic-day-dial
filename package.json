{
  "name": "islamic-day-dial",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts'",
    "typecheck": "tsc --build",
    "precommit": "npm run lint && npm run typecheck && npm test",
    "test:wear": "cd apps/wear-watchface && ./gradlew testDebugUnitTest",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.0.0"
  }
}
