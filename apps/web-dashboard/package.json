{
  "name": "@islamic-day-dial/web-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "favicon": "node scripts/generate-favicon.mjs",
    "build": "tsc --noEmit && vite build",
    "build:demo": "tsc --noEmit && VITE_DEMO_MODE=true vite build && cp dist/index.html dist/404.html && touch dist/.nojekyll",
    "preview": "vite preview"
  },
  "dependencies": {
    "@islamic-day-dial/core": "*",
    "@supabase/supabase-js": "^2.99.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "vite": "^6.3.0"
  }
}
